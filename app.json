{
  "expo": {
    "name": "Quranly",
    "slug": "quranly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/icon.png",
    "scheme": "quranly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icons/icon.png",
      "bundleIdentifier": "com.anonymous.quranly"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/icons/icon-adaptive.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.anonymous.quranly"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icons/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/icons/splash-screen.png",
          "imageWidth": 240
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Izinkan akses lokasi untuk menampilkan jadwal shalat di kotamu."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6366F1",
          "sounds": []
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
